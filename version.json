    "health":          "https://intel.cyberdudebivash.com/health"
  },
  "auth": {
    "type":              "JWT_HS256",
    "token_endpoint":    "POST /api/auth/token",
    "validate_endpoint": "GET /api/auth/validate",
    "token_ttl_days":    30,
    "secret_env":        "CDB_JWT_SECRET",
    "note": "Exchange API key for JWT via /api/auth/token. Use JWT as Bearer token for all authenticated endpoints."
  },
  "apex_ai": {
    "version": "3.0",
    "fields": ["predictive_risk","ai_confidence","actor_fingerprint","kill_chain","ttp_density","threat_confidence_tier"],
    "confidence_tiers": ["LOW","MODERATE","HIGH","VERIFIED"],
    "tier_gating": {
      "free":       ["predictive_risk","ai_confidence","ttp_density","soc_priority","threat_level","threat_confidence_tier"],
      "pro":        ["all_fields"],
      "enterprise": ["all_fields","stix_bundle"]
    },
    "paywall_locked_free": ["actor_fingerprint_full","kill_chain","ai_summary","behavioral_tags","ioc_arrays","stix_bundle"]
  },
  "subscription_tiers": {
    "free": {
      "label":      "FREE",
      "api_rpm":    10,
      "feed_limit": 10,
      "reports":    "public",
      "stix":       false,
      "alerts":     false,
      "jwt":        true,
      "apex_ai":    "partial",
      "ioc_data":   "count_only"
    },
    "pro": {
      "label":      "PRO",
      "api_rpm":    500,
      "feed_limit": 500,
      "reports":    "full",
      "stix":       true,
      "alerts":     true,
      "jwt":        true,
      "apex_ai":    "full",
      "ioc_data":   "full_arrays"
    },
    "enterprise": {
      "label":         "ENTERPRISE",
      "api_rpm":       0,
      "feed_limit":    0,
      "reports":       "full",
      "stix":          true,
      "alerts":        true,
      "siem":          true,
      "soar":          true,
      "dedicated_sla": true,
      "jwt":           true,
      "apex_ai":       "full",
      "ioc_data":      "full_arrays",
      "stix_bundle_raw": true
    }
  }
}
