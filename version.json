  "endpoints": {
    "dashboard":       "https://intel.cyberdudebivash.com",
    "api_base":        "https://intel.cyberdudebivash.com/api",
    "preview":         "https://intel.cyberdudebivash.com/api/preview",
    "feed":            "https://intel.cyberdudebivash.com/api/feed",
    "intelligence":    "https://intel.cyberdudebivash.com/api/intelligence",
    "stix_api":        "https://intel.cyberdudebivash.com/api/stix",
    "auth_token":      "https://intel.cyberdudebivash.com/api/auth/token",
