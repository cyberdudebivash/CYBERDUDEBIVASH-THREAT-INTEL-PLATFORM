// SENTINEL APEX — Tata Electronics Confirms Data Breach After 630GB Leak Claim Targets Apple and Tesla — Anomalous Activity Detection
// Product: Web Application | Generated: 2026-06-25T22:11:43Z
let lookback = 1d;
SecurityEvent
| where TimeGenerated > ago(lookback)
| where EventID in (4625, 4648, 4728, 4740, 4776)
| summarize FailureCount = count(), DistinctTargets = dcount(TargetUserName)
    by IpAddress, bin(TimeGenerated, 1h)
| where FailureCount > 10 or DistinctTargets > 5
| extend Severity = "MEDIUM", CVE = "Tata Electronics Confirms Data Breach After 630GB Leak Claim Targets Apple and Tesla", RuleSource = "SENTINEL-APEX"
| order by TimeGenerated desc

