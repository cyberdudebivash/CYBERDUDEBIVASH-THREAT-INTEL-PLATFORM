// ── [SILVER] Critical: A VBScript campaign distributed through WhatsApp deploying RMM softwar
// CVE: CVE-2026-12581
// Risk: 5.50 | Severity: MEDIUM
// STIX ID: intel--1782124391_CVE-2026-12580_CVE-2026-12581_CVE-2026-4
// SENTINEL APEX — Phishing Campaign Detection
// CVE/Threat: CVE-2026-12581 | Generated: 2026-06-23T06:13:51Z
let lookback = 7d;
let suspicious_exts = dynamic([".hta", ".lnk", ".iso", ".vhd", ".docm", ".xlsm", ".pptm"]);
EmailAttachmentInfo
| where Timestamp > ago(lookback)
| where FileName has_any (suspicious_exts)
| join kind=leftouter (
    EmailEvents | where Timestamp > ago(lookback)
        | where DeliveryAction !in ("Blocked", "Junked")
) on NetworkMessageId
| project Timestamp, RecipientEmailAddress, SenderFromAddress, FileName,
          Subject, DeliveryAction
| extend Severity = "HIGH", ThreatType = "Phishing", RuleSource = "SENTINEL-APEX"
| order by Timestamp desc

