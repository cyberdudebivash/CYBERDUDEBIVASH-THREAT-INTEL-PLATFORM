e.html?plan=pro"},{"id":"intel--38c9ab434368aa1dbb8364c4","stix_id":"intel--38c9ab434368aa1dbb8364c4","title":"golang.org/x/crypto/ssh/agent doesn't drop invoking agent constraints when forwarding keys","description":"When adding a key to a remote agent constraint extensions such as restrict-destination-v00@openssh.com were not serialized in the request. Destination restrictions were silently stripped when forwarding keys, allowing unrestricted use of the key on the remote host. The client now serializes all constraint extensions. Additionally, the in-memory keyring returned by NewKeyring() now rejects keys with unsupported constraint extensions instead of silently ignoring them.","severity":"CRITICAL","risk_score":9.0277,"confidence":0.45,"source":"GitHub Security Advisories","feed_source":"GitHub Security Advisories","tlp":"TLP:CLEAR","threat_type":"Vulnerability","tags":["go:golang.org/x/crypto/ssh/agent"],"cve_id":"CVE-2026-39832","cve_ids":["CVE-2026-39832"],"ioc_count":0,"kev":"NO","timestamp":"2026-06-25T22:14:00Z","processed_at":"2026-06-25T22:14:00Z","published_at":"2026-06-25T22:14:00Z","source_url":"https://github.com/advisories/GHSA-f5wc-c3c7-36mc","actor":"CDB-UNATTR-CVE","ghsa_id":"GHSA-f5wc-c3c7-36mc","epss_score":0.4,"epss":"0.4%","cvss_score":9.1,"cvss_vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:N","cvss_source":"github_advisory","exploit_maturity":"POC","exploit_count":0,"exploit_refs":[],"metasploit_available":false,"poc_github_count":0,"actor_display_name":"Unknown Threat Actor","actor_aliases":["Unattributed"],"actor_country":"Unknown","actor_motivation":["unknown"],"actor_sectors":[],"actor_ttps":[],"actor_malware":[],"actor_threat_level":"UNKNOWN","actor_mitre_id":null,"iq_score":45,"iq_breakdown":{"source":10,"enrichment":15,"attribution":5,"corroboration":15},"intelligence_age_days":0.5,"confidence_label":"MEDIUM_CONFIDENCE","confidence_score_v2":26,"confidence_rationale":"Medium confidence — CVSS score 9.1 (Critical)","confidence_fa