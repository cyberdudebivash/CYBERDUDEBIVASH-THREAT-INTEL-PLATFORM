    "tlp": "TLP:CLEAR",
    "actor_tag": "UNC-CDB-INGEST",
    "apex_ai_summary": "[MEDIUM] CVE advisory. Risk score 6.5/10. Full APEX AI analysis available to Pro subscribers.",
    "apex_ai_score": 6.5,
