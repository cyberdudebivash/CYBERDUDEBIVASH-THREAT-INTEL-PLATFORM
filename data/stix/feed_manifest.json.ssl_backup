    "tlp": "TLP:CLEAR",
    "actor_tag": "UNC-CDB-INGEST",
    "apex_ai_summary": "[HIGH] OSS-ADVISORY advisory. Risk score 8.8/10. Full APEX AI analysis available to Pro subscribers.",
    "apex_ai_score": 8.8,
