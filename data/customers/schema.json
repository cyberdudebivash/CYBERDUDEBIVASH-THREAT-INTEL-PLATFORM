{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intel.cyberdudebivash.com/schemas/customer.json",
  "title": "SENTINEL APEX Customer Schema v1.0",
  "description": "Canonical schema for a SENTINEL APEX customer record",
  "type": "object",
  "required": ["id", "reference_id", "name", "email", "plan", "status", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Internal UUID (auto-generated)"
    },
    "reference_id": {
      "type": "string",
      "pattern": "^SA-[0-9]{8}-[A-Z0-9]{4}$",
      "description": "Customer-facing reference ID, e.g. SA-20260604-A7X2",
      "examples": ["SA-20260604-A7X2"]
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "description": "Customer full name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Primary contact email"
    },
    "company": {
      "type": "string",
      "description": "Company or organization name"
    },
    "job_title": {
      "type": "string",
      "description": "Customer job title"
    },
    "country": {
      "type": "string",
      "minLength": 2,
      "maxLength": 2,
      "description": "ISO 3166-1 alpha-2 country code"
    },
    "whatsapp": {
      "type": "string",
      "description": "WhatsApp number with country code"
    },
    "gstin": {
      "type": "string",
      "pattern": "^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$",
      "description": "Indian GST Identification Number (15 chars)"
    },
    "plan": {
      "type": "string",
      "enum": ["community", "pro", "enterprise", "mssp", "trial"],
      "description": "Active subscription plan tier"
    },
    "billing_cycle": {
      "type": "string",
      "enum": ["monthly", "annual", "free"],
      "description": "Billing frequency"
    },
    "use_case": {
      "type": "string",
      "description": "Primary intended use case"
    },
    "siem_platform": {
      "type": "string",
      "description": "Customer's primary SIEM platform"
    },
    "org_size": {
      "type": "string",
      "description": "Organization headcount band"
    },
    "status": {
      "type": "string",
      "enum": ["pending_verification", "verified", "active", "grace", "suspended", "expired", "cancelled"],
      "description": "Current account lifecycle status"
    },
    "api_key_hash": {
      "type": "string",
      "description": "SHA-256 hash of issued API key (NOT the plaintext key)"
    },
    "key_issued_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when API key was delivered"
    },
    "subscription_start": {
      "type": "string",
      "format": "date-time",
      "description": "Subscription start date (UTC)"
    },
    "subscription_expiry": {
      "type": "string",
      "format": "date-time",
      "description": "Subscription expiry date (UTC)"
    },
    "renewal_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Number of times customer has renewed"
    },
    "support_channel": {
      "type": "string",
      "enum": ["email", "whatsapp", "whatsapp_group", "dedicated"],
      "description": "Primary support channel for this customer"
    },
    "whatsapp_group": {
      "type": "string",
      "description": "WhatsApp group name if applicable (ENTERPRISE/MSSP)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp (UTC)"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp (UTC)"
    },
    "notes": {
      "type": "string",
      "description": "Operator notes"
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Optional tags for segmentation"
    }
  },
  "additionalProperties": false
}
