index=endpoint ParentImage IN ("*WINWORD.EXE","*EXCEL.EXE","*POWERPNT.EXE","*OUTLOOK.EXE")
  Image IN ("*cmd.exe","*powershell.exe","*wscript.exe","*cscript.exe","*mshta.exe","*rundll32.exe","*certutil.exe")
| eval severity="HIGH"
| eval mitre_technique="T1566.001"
| table _time, host, user, ParentImage, Image, CommandLine, severity, mitre_technique