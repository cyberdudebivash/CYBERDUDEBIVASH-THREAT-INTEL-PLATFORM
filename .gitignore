!data/analyst/analyst_report.json
!data/arsenal/arsenal_report.json
!data/convergence/convergence_report.json
!data/intelligence/detection_rules/rule_manifest.json

# --- API ENDPOINT FILES — PIPELINE STATE (un-ignored) ---
# api/ dir is committed — these are the live feed endpoints
!api/feed.json
!api/latest.json
!api/status.json

