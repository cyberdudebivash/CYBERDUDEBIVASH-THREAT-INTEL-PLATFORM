# =================================================================
# CYBERDUDEBIVASH® SENTINEL APEX v101 — MASTER IGNORE FILE
# Last enforced: v101.0.0 — PERMANENT PRODUCTION CONTRACT
# Architecture: Runtime-generated volatile data excluded;
#               Pipeline-critical state files EXPLICITLY ALLOWED.
# =================================================================

# --- SOVEREIGNTY & AUTH (NEVER PUSH) ---
secrets/
*.pem
*.key
*.pfx
credentials/
token.json
credentials.json
.env

# --- ENTERPRISE SELLABLE ASSETS (protect revenue, upload via Gumroad engine) ---
data/rule_packs/
data/playbooks/
data/certificates/
data/enterprise_kits/
data/temp/

# --- RUNTIME-VOLATILE DATA (generated fresh each cycle — NOT committed) ---
data/blogger_processed.json
data/sentinel_apex.db
data/manifest_audit.json
data/manifest_backups/
data/.manifest_backups/
data/manifest_versions/
data/logs/
*.log

# --- HIGH-VOLUME STIX INDIVIDUAL OBJECTS (committed via -f by sentinel-blogger) ---
# These are large individual advisory JSON files — exclude from default tracking
# The feed_manifest.json AGGREGATION is what matters and IS committed.
data/stix/CDB-APEX-*.json

# --- PIPELINE-CRITICAL STATE FILES — EXPLICITLY UN-IGNORED ---
# These MUST be committed so all downstream workflows find them on checkout.
!data/stix/feed_manifest.json
!data/sync_marker.json
!data/alert_history.json
!data/audit_log.json
!data/publish_queue.json
!data/pending_publish.json
!data/revenue_log.json
!data/telemetry_log.json
