# =============================================================================
# CYBERDUDEBIVASH® SENTINEL APEX — Docker Build Exclusions
# v100.0 — Corrected: no longer excludes api/, core/, sdk/, data/, agent/
# =============================================================================

# ── Version control ──────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Python cache (always regenerated) ────────────────────────────────────────
__pycache__
*.pyc
*.pyo
*.pyd
*.pycache
.pytest_cache
.mypy_cache
.ruff_cache

# ── Secrets (NEVER in image) ──────────────────────────────────────────────────
.env
.env.*
secrets/
*.pem
*.key
*.pfx
credentials/
token.json
credentials.json

# ── Python virtualenvs ────────────────────────────────────────────────────────
venv/
.venv/
env/
.python-version
*.egg-info/
dist/
build/
*.whl

# ── Node (not needed in Python image) ────────────────────────────────────────
node_modules/
npm-debug.log
yarn-error.log
package-lock.json

# ── Dev/test artifacts ────────────────────────────────────────────────────────
.coverage
htmlcov/
.tox/
*.log

# ── Large binary/media (not needed at runtime) ────────────────────────────────
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.mp4
*.zip
*.tar.gz
*.7z

# ── Documentation (not needed at runtime) ────────────────────────────────────
*.md
docs/
notebooks/

# ── CI/dev scripts not needed in production image ─────────────────────────────
*.sh
*.bat
*.patch
blogs/
reports/
exports/

# ── Large data subdirs NOT needed at runtime (regenerated by engines) ─────────
data/rule_packs/
data/certificates/
data/enterprise_kits/
data/temp/
data/exports/
data/blogger_processed.json
data/manifest_backups/

# ── Test artifacts (tests/ source IS included for import resolution) ──────────
tests/__pycache__
tests/.pytest_cache

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
