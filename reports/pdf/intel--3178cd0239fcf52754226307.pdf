  .reg-matrix{grid-template-columns:1fr}
  .exec-card{grid-template-columns:repeat(2,1fr)}
  .plv2-features{grid-template-columns:1fr}
  .nav-actions .nav-btn-stix,.nav-actions .nav-btn-upgrade{display:none}
}
</style>
