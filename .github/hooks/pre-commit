#!/usr/bin/env bash
# .github/hooks/pre-commit
# ================================================================================
# SENTINEL APEX — Pre-Commit Repository Integrity Hook v1.0
# ================================================================================
# Prevents null-byte corrupted Python files from entering the repository.
# Installed by: scripts/null_byte_guard.py setup
#
# ROOT CAUSE BLOCKED HERE:
#   Cross-OS mount writes (Linux tmpfs → Windows NTFS) produce null-padded files.
#   This hook catches corruption BEFORE commit, never letting it reach main.
# ================================================================================
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
GUARD="${REPO_ROOT}/scripts/null_byte_guard.py"
VIOLATIONS=0
CHECKED=0

# Collect staged .py files
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -z "$STAGED_PY" ]; then
    exit 0  # No Python files staged
fi

echo "🔍 [NULL-BYTE-GUARD] Scanning $(echo "$STAGED_PY" | wc -l) staged Python file(s)..."

for FILE in $STAGED_PY; do
    FULL_PATH="${REPO_ROOT}/${FILE}"
    if [ ! -f "$FULL_PATH" ]; then
        continue
    fi

    CHECKED=$((CHECKED + 1))

    # Layer 1: null-byte detection (binary grep — fastest)
    if python3 -c "
import sys
d = open('${FULL_PATH}', 'rb').read()
n = d.count(b'\\x00')
if n:
    print(f'  ❌ NULL BYTES: ${FILE} contains {n} null bytes')
    sys.exit(1)
" 2>&1; then
        : # clean
    else
        VIOLATIONS=$((VIOLATIONS + 1))
        continue
    fi

    # Layer 2: UTF-8 validation
    if ! python3 -c "open('${FULL_PATH}', encoding='utf-8').read()" 2>/dev/null; then
        echo "  ❌ UTF-8 ERROR: ${FILE}"
        VIOLATIONS=$((VIOLATIONS + 1))
        continue
    fi

    # Layer 3: AST syntax check
    if ! python3 -m py_compile "${FULL_PATH}" 2>/dev/null; then
        echo "  ❌ SYNTAX ERROR: ${FILE}"
        VIOLATIONS=$((VIOLATIONS + 1))
        continue
    fi

    echo "  ✅ CLEAN: ${FILE}"
done

echo ""
echo "Checked: ${CHECKED} | Violations: ${VIOLATIONS}"

if [ "${VIOLATIONS}" -gt 0 ]; then
    echo ""
    echo "❌ PRE-COMMIT BLOCKED: ${VIOLATIONS} file(s) have integrity violations."
    echo "   Run: python3 scripts/null_byte_guard.py --fix"
    echo "   Then re-stage: git add <fixed files>"
    exit 1
fi

echo "✅ Integrity check PASSED"
exit 0
