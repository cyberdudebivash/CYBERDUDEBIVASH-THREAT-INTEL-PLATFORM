{
  "title": "SENTINEL APEX — SOC Operations Dashboard",
  "uid": "sentinel-apex-soc",
  "tags": ["sentinel-apex", "soc", "production"],
  "timezone": "UTC",
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Active Critical Alerts",
      "type": "stat",
      "targets": [{ "expr": "sum(sentinel_soc_alerts_total{severity='critical',status='active'})", "legendFormat": "Critical" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color":"green","value":0},{"color":"orange","value":3},{"color":"red","value":10}] } } }
    },
    {
      "id": 2,
      "title": "Mean Time to Detect (MTTD)",
      "type": "gauge",
      "targets": [{ "expr": "sentinel_soc_mttd_hours", "legendFormat": "MTTD (hours)" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 24, "unit": "h" } }
    },
    {
      "id": 3,
      "title": "AI Auto-Resolution Rate",
      "type": "stat",
      "targets": [{ "expr": "sentinel_soc_auto_resolved_pct", "legendFormat": "%" }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 4,
      "title": "Alert Volume (24h)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(sentinel_soc_alerts_total[5m]) * 300", "legendFormat": "{{severity}}" }
      ]
    },
    {
      "id": 5,
      "title": "API Gateway — Request Rate",
      "type": "timeseries",
      "targets": [{ "expr": "rate(http_requests_total{job='api-gateway'}[1m])", "legendFormat": "req/s" }]
    },
    {
      "id": 6,
      "title": "AI Engine — Inference Latency p99",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.99, rate(ai_inference_duration_seconds_bucket[5m]))", "legendFormat": "p99 latency" }]
    }
  ]
}
