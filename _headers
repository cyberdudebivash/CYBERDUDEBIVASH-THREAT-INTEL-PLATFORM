# CYBERDUDEBIVASH® SENTINEL APEX v142.3.1 — Production Security & Cache Headers
# Hardened: 2026-05-02
# Coverage: HSTS · CSP · X-XSS · X-Frame · CORP · COOP · Referrer · Permissions
# All headers validated against OWASP Secure Headers Project v4.0

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=(), interest-cohort=()
  Cross-Origin-Resource-Policy: same-origin
  Cross-Origin-Opener-Policy: same-origin
  X-Sentinel-Version: 142.3.1
  X-Sentinel-Platform: CYBERDUDEBIVASH-SENTINEL-APEX

/*.html
  Cache-Control: no-cache, must-revalidate
  Content-Security-Policy: default-src 'self' https://intel.cyberdudebivash.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://intel.cyberdudebivash.com https://www.cyberdudebivash.in https://formspree.io https://api.stripe.com; frame-ancestors 'none'; form-action 'self' https://formspree.io https://checkout.stripe.com; base-uri 'self'; upgrade-insecure-requests;
  X-Sentinel-Version: 142.3.1

/api/*
  Cache-Control: no-store, no-cache, must-revalidate
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, POST, OPTIONS
  Access-Control-Allow-Headers: Authorization, Content-Type, X-API-Key, X-Sentinel-Version
  Access-Control-Max-Age: 86400
  X-Sentinel-Version: 142.3.1
  Cross-Origin-Resource-Policy: cross-origin

/api/feed.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Access-Control-Allow-Origin: *
  Content-Type: application/json; charset=utf-8
  X-Sentinel-Version: 142.3.1

/api/status.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Access-Control-Allow-Origin: *

/data/feed_manifest.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Access-Control-Allow-Origin: *

/data/stix/feed_manifest.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Access-Control-Allow-Origin: *

/config/version.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Access-Control-Allow-Origin: *

/assets/*
  Cache-Control: public, max-age=604800, immutable

/js/*
  Cache-Control: public, max-age=604800, immutable
