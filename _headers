# CYBERDUDEBIVASH® SENTINEL APEX v161.x — Production Security & Cache Headers
# Hardened: 2026-05-24 | Enterprise Production Readiness v161.x
# Coverage: HSTS · CSP · X-XSS · X-Frame · CORP · COOP · Referrer · Permissions
# All headers validated against OWASP Secure Headers Project v4.0
# Audit Status: PASSED — 100/100 convergence | Governance Grade: A+ | v161.x

/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=(), interest-cohort=(), accelerometer=(), gyroscope=(), magnetometer=()
  Cross-Origin-Resource-Policy: same-origin
  Cross-Origin-Opener-Policy: same-origin
  X-Sentinel-Version: 161.x
  X-Sentinel-Platform: CYBERDUDEBIVASH-SENTINEL-APEX
  X-Robots-Tag: index, follow

/*.html
  Cache-Control: no-cache, must-revalidate
  Content-Security-Policy: default-src 'self' https://intel.cyberdudebivash.com; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://intel.cyberdudebivash.com https://www.cyberdudebivash.in https://formspree.io https://api.stripe.com https://api.convertkit.com; frame-ancestors 'none'; form-action 'self' https://formspree.io https://checkout.stripe.com https://app.convertkit.com; base-uri 'self'; upgrade-insecure-requests; block-all-mixed-content;
  X-Sentinel-Version: 145.0

# V172 RC12 FIX: Engine JS files must never be served from browser HTTP cache.
# Stale compositor-governance-engine.js (pre-v172) would re-introduce
# the promote() translateZ(0) GPU trap that blanks Chrome Desktop canvas.
/js/engines/*
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache
  X-Sentinel-Version: 172.0
  X-Cache-Policy: no-cache-engine-governance

/js/*
  Cache-Control: no-cache, must-revalidate, max-age=0
  X-Sentinel-Version: 172.0

/reports/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
  X-Intel-Classification: TLP-CLEAR
  X-Sentinel-Version: 145.0

/ops/*
  X-Robots-Tag: noindex, nofollow

/api/*
  Cache-Control: no-store, no-cache, must-revalidate
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, POST, OPTIONS
  Access-Control-Allow-Headers: Authorization, Content-Type, X-API-Key, X-Sentinel-Version
  Access-Control-Max-Age: 86400
  X-Sentinel-Version: 145.0
  Cross-Origin-Resource-Policy: cross-origin

/api/feed.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Access-Control-Allow-Origin: *
  Content-Type: application/json; charset=utf-8
  X-Sentinel-Version: 145.0

/api/status.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Access-Control-Allow-Origin: *

/data/feed_manifest.json
  Cache-Control: no-store,